{
  "name": "edu-agent-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:backend": "set -a; [ -f .env.local ] && . ./.env.local; set +a; PYTHONPATH=backend python3 -m uvicorn backend.api.main:app --host 0.0.0.0 --port 8000 --reload",
    "dev:frontend": "npm run dev --prefix frontend",
    "test": "PYTHONPATH=backend python3 eval/run_core_evals.py --smoke",
    "test:mcp": "PYTHONPATH=backend python3 eval/mcp_server_smoke.py",
    "test:rag-inspector": "PYTHONPATH=backend python3 eval/rag_inspector_smoke.py",
    "test:agent-ops": "PYTHONPATH=backend python3 eval/agent_ops_smoke.py",
    "test:textbook-trace": "PYTHONPATH=backend python3 eval/textbook_trace_smoke.py",
    "test:autotutor-recovery": "PYTHONPATH=backend python3 eval/autotutor_session_recovery_smoke.py",
    "test:release-gate": "PYTHONPATH=backend python3 eval/release_gate_smoke.py",
    "mcp:server": "PYTHONPATH=backend python3 -m backend.mcp_server",
    "test:prod-rag": "PYTHONPATH=backend python3 eval/run_core_evals.py --suite production_rag_health_smoke --no-report",
    "release:gate": "PYTHONPATH=backend python3 scripts/release_gate.py",
    "release:gate:fast": "PYTHONPATH=backend python3 scripts/release_gate.py --fast",
    "release:gate:prod": "PYTHONPATH=backend python3 scripts/release_gate.py --production"
  }
}
