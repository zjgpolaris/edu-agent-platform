# 前端整棵树（后端镜像不需要）
frontend

# 依赖与构建产物
node_modules
**/node_modules
**/__pycache__
*.pyc
.venv
venv

# 本地向量库 / 大语料（运行时挂载或重建，不进镜像）
.chroma
# RAG 大语料 corpus.json 不进镜像（RAG 会降级），但历史地图的 geo_events.json 是
# 历史时空页的数据源，需打进后端镜像，故排除整个 knowledge_base 后单独放行 history 小数据。
knowledge_base
!knowledge_base/history
knowledge_base/history/corpus.json
# textbooks 的原始 PDF/OCR 不进镜像，但结构化教材 YAML 是教材同步学习页的数据源，必须打进后端镜像
textbooks/*
!textbooks/structured
scripts
eval

# 版本控制与本地环境
.git
.gitignore
.env
.env.*
!.env.example

# 编辑器 / 系统
.DS_Store
.vscode
.idea
*.log

# 文档
docs
*.md
