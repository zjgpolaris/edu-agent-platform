# 前端整棵树（后端镜像不需要）
frontend

# 依赖与构建产物
node_modules
**/node_modules
**/__pycache__
*.pyc
.venv
venv

# 本地向量库 / 大语料（运行时挂载或重建，不进镜像）
.chroma
# 真正重的是 .chroma 向量库与 BGE 模型；knowledge_base/history 下只是小数据
# （corpus.json 2.3MB + geo_events 60K），是历史地图与游戏 LLM 出题的上下文源，需进镜像。
knowledge_base
!knowledge_base/history
# textbooks 的原始 PDF/OCR 不进镜像，但结构化教材 YAML 是教材同步学习页的数据源，必须打进后端镜像
textbooks/*
!textbooks/structured
scripts
eval

# 版本控制与本地环境
.git
.gitignore
.env
.env.*
!.env.example

# 编辑器 / 系统
.DS_Store
.vscode
.idea
*.log

# 文档
docs
*.md
